# ============================================
# Jaan Group Ration Distribution App — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================

# --- OpenAI (Chatbot) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Qdrant (Vector DB for beneficiary search) ---
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=beneficiaries

# --- Hugging Face Inference API ---
HUGGINGFACE_API_KEY=hf_your-huggingface-token

# --- Google Sheets (Transparency backup) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id

# --- App Settings ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SECRET=change-this-to-a-strong-secret
